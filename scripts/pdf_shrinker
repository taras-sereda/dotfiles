#!/bin/bash

if [ $# -lt 1 ]; then
  echo "Usage: pdf_shrinker <input.pdf> [output.pdf]"
  exit 1
fi

INPUT="$1"

if [ ! -f "$INPUT" ]; then
  echo "Error: file not found: $INPUT"
  exit 1
fi

if [ -n "$2" ]; then
  OUTPUT="$2"
else
  BASENAME="${INPUT%.pdf}"
  OUTPUT="${BASENAME}-small.pdf"
fi

echo "Shrinking: $INPUT -> $OUTPUT"

gs -sDEVICE=pdfwrite -dCompatibilityLevel=1.4 -dPDFSETTINGS=/ebook \
   -dNOPAUSE -dQUIET -dBATCH \
   -sOutputFile="$OUTPUT" "$INPUT"

if [ $? -eq 0 ]; then
  INPUT_SIZE=$(du -sh "$INPUT" | cut -f1)
  OUTPUT_SIZE=$(du -sh "$OUTPUT" | cut -f1)
  echo "Done! $INPUT_SIZE -> $OUTPUT_SIZE"
else
  echo "Error: Ghostscript failed"
  exit 1
fi
